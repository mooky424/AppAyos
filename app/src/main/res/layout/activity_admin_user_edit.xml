<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F1F9"
    android:padding="16dp"
    tools:context=".AdminUserEdit">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <LinearLayout
                 android:id="@+id/editUser_container_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                     android:id="@+id/editUser_back"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackground"
                    android:contentDescription="Back Button"
                    android:scaleType="centerInside"
                    android:src="@drawable/back_finaldesign" />

                <TextView
                     android:id="@+id/editUser_header"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/bree_serif"
                    android:text="Edit User"
                    android:textColor="#282032"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/nunito_medium"
                android:text="Username"
                android:textColor="#282032"
                android:textStyle="bold" />

            <EditText
                 android:id="@+id/changeUsername_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/inputbox"
                android:fontFamily="@font/nunito_medium"
                android:hint="Enter username"
                android:inputType="text"
                android:padding="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/nunito_medium"
                android:text="Password"
                android:textColor="#282032"
                android:textStyle="bold" />

            <EditText
                 android:id="@+id/changePassword_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/inputbox"
                android:fontFamily="@font/nunito_medium"
                android:hint="Enter password"
                android:inputType="textPassword"
                android:padding="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/nunito_medium"
                android:text="Password Confirm"
                android:textColor="#282032"
                android:textStyle="bold" />

            <EditText
                 android:id="@+id/changePasswordConfirm_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/inputbox"
                android:fontFamily="@font/nunito_medium"
                android:hint="Confirm password"
                android:inputType="textPassword"
                android:padding="10dp" />

            <CheckBox
                 android:id="@+id/editUser_admin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/nunito_medium"
                android:text="Admin"
                android:textColor="#282032" />

            <CheckBox
                 android:id="@+id/editUser_technician"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_medium"
                android:text="Technician"
                android:textColor="#282032" />

            <Button
                 android:id="@+id/saveEditedUser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="#282032"
                android:fontFamily="@font/nunito_medium"
                android:text="Save" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
