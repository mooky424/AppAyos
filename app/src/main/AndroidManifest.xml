<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- NEW: application permissions -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- NEEDED TO ACCESS CAMERA and GALLERY FOR ANDROID 11+ -->
    <!-- https://stackoverflow.com/questions/62535856/intent-resolveactivity-returns-null-in-api-30/64204646#64204646 -->
    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
        <intent>
            <action android:name="android.intent.action.GET_CONTENT" />
        </intent>
    </queries>

    <application
         android:name=".RealmLab"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppAyos">
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="@string/fileAuthority"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_path" />
        </provider>

        <activity
             android:name=".Login"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".Register"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ImageActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
             android:name=".UserRequestsLists"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
             android:name=".Settings"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
             android:name=".Tracker"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
             android:name=".CreateRequest"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
             android:name=".EditRequest"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
             android:name=".SubmitPhoto"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
             android:name=".PendingRequests"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
             android:name=".CompleteRequest"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
             android:name=".UsersList"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
             android:name=".EditUser"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
             android:name=".AdminEditUser"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
    </application>

</manifest>
